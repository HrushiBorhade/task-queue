# Deny-by-default: ignore everything, then allow what we need.
# This is safer than listing exclusions — new files/dirs are
# automatically excluded without updating this file.
*

# ── Allow: workspace manifests (needed for lockfile resolution) ──
!package.json
!bun.lock
!tsconfig.json
!packages/shared/package.json
!apps/worker/package.json
!apps/web/package.json
!apps/trigger/package.json

# ── Allow: source code we actually ship ──
!packages/shared/
!apps/worker/
